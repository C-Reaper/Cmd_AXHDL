from unsigned import *
from std import *
from seg7 import *

arch HADD
    unsigned<1> in x
    unsigned<1> in y
    unsigned<1> out z
    unsigned<1> out w
    
    chip AND a0
        a0.a = x
        a0.b = y
    end
    chip XOR a1
        a1.a = x
        a1.b = y
    end

    chip SEG7 a2
        a2.a = a0.c
    end
    chip SEG7 a3
        a3.a = a1.c
    end

    z = a0.c
    w = a1.c
end