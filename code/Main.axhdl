from unsigned import *
from std import *
from seg7 import *

arch MAIN
    unsigned<1> in x
    unsigned<1> in y
    unsigned<1> out z
    
    chip MUX m0
        m0.a = x
        m0.b = y
        m0.c = x > y
        z = m0.d
    end

    chip SEG7 s0
        s0.a = x
    end
    chip SEG7 s1
        s1.a = y
    end
    chip SEG7 s2
        s2.a = m0.d
    end
end