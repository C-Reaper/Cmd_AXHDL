from unsigned import *
from std import *
from seg7 import *

arch TEST
    unsigned<1> in x
    unsigned<1> in y
    unsigned<1> out oa
    unsigned<1> out ob
    unsigned<1> out oc
    unsigned<1> out od

    chip AND a0
        x => a0.a
        y => a0.b
        a0.c => oa
    end
    chip NOT a1
        x => a1.a
        a1.b => ob
    end
    chip OR a2
        x => a2.a
        y => a2.b
        a2.c => oc
    end
    chip XOR a3
        x => a3.a
        y => a3.b
        a3.c => od
    end
    chip SEG7 a4
        x => a4.a
    end
end