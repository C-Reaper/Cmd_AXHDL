from unsigned import *
from std import *
from seg7 import *

arch TEST
    unsigned<1> in x
    unsigned<1> in y
    unsigned<1> out oa
    unsigned<1> out ob
    unsigned<1> out oc
    unsigned<1> out od
    unsigned<1> out oe

    chip AND a0
        a0.a = x
        a0.b = y
        oa = a0.c
    end
    chip NOT a1
        a1.a = x
        ob = a1.b
    end
    chip OR a2
        a2.a = x
        a2.b = y
        oc = a2.c
    end
    chip XOR a3
        a3.a = x
        a3.b = y
        od = a3.c
    end
    chip SEG7 a4
        a4.a = x
    end

    chip MUX a5
        a5.a = x
        a5.b = y
        a5.c = x > y
        oe = a5.d
    end
end